@model IEnumerable<BusinessNewsApp.Models.Article>

@{
    ViewData["Title"] = "Business News";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Business News</h1>
        <p class="text-muted fs-5">
            Stay updated with the latest business headlines from trusted sources.
        </p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var article in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card news-card h-100 shadow-sm border-0">
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-light text-dark mb-3 source-badge">
                                @article.Source.Name
                            </span>

                            <h5 class="card-title fw-semibold">@article.Title</h5>

                            <div class="mt-auto pt-3">
                                <a href="@article.Url" target="_blank" class="btn btn-primary btn-sm">
                                    Read Full Article
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-warning text-center">
                    No news articles found. Check your API key or internet connection.
                </div>
            </div>
        }
    </div>
</div>